# ── Backend Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values

NODE_ENV=production
PORT=10000

# Option A: Use DATABASE_URL (Neon / Railway / Supabase)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Option B: Individual DB vars (local dev only)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=transitops
# DB_USER=postgres
# DB_PASSWORD=your_password

# JWT
JWT_SECRET=change-this-to-a-very-long-random-string-minimum-32-chars
JWT_EXPIRE=7d

# Frontend URL (set to your Vercel URL after deployment)
FRONTEND_URL=https://your-app.vercel.app
